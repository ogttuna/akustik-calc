{
  "name": "dynecho",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "calculator:gate:current": "tsx tools/dev/run-calculator-current-gate.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "dev": "turbo run dev --parallel --filter=@dynecho/web",
    "docker:build": "docker build -t dynecho-web .",
    "docker:up": "docker compose up --build",
    "e2e": "tsx tools/dev/run-playwright.ts",
    "engine:benchmark-airborne": "tsx tools/engine/benchmark-airborne.ts",
    "engine:estimate": "tsx tools/engine/estimate.ts",
    "lint": "pnpm lint:repo && turbo run lint",
    "lint:repo": "eslint tools e2e playwright.config.ts",
    "test": "turbo run test",
    "typecheck": "pnpm typecheck:repo && turbo run typecheck",
    "typecheck:repo": "tsc --project tsconfig.json",
    "upstream:compare": "tsx tools/upstream/compare-estimate.ts",
    "upstream:estimate": "tsx tools/upstream/estimate.ts",
    "upstream:impact-only-parity": "tsx tools/upstream/compare-impact-only-parity.ts",
    "upstream:impact-parity": "tsx tools/upstream/compare-impact-parity.ts",
    "upstream:inventory": "tsx tools/upstream/report-inventory.ts",
    "upstream:note": "tsx tools/upstream/create-import-note.ts",
    "upstream:refresh-workbench": "tsx tools/upstream/refresh-workbench-snapshot.ts",
    "upstream:status": "tsx tools/upstream/report-status.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@eslint/js": "^9.24.0",
    "@next/eslint-plugin-next": "^15.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.24.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.5.0",
    "turbo": "^2.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.29.0",
    "vitest": "^3.1.0"
  }
}
